{
  "name": "autopilot-airr",
  "private": true,
  "packageManager": "npm@10.2.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "db:push": "cd packages/db && npm run push",
    "db:studio": "cd packages/db && npm run studio"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  }
}
