{
  "name": "my-better-t-app",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "nx run-many -t dev",
    "build": "nx run-many -t build",
    "check-types": "nx run-many -t check-types",
    "dev:web": "nx run-many -t dev --projects=web",
    "dev:server": "nx run-many -t dev --projects=server",
    "db:push": "nx run-many -t db:push --projects=@my-better-t-app/db",
    "db:studio": "nx run-many -t db:studio --projects=@my-better-t-app/db",
    "db:generate": "nx run-many -t db:generate --projects=@my-better-t-app/db",
    "db:migrate": "nx run-many -t db:migrate --projects=@my-better-t-app/db",
    "db:local": "nx run-many -t db:local --projects=@my-better-t-app/db"
  },
  "dependencies": {
    "@my-better-t-app/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@my-better-t-app/config": "workspace:*",
    "@types/node": "^22.13.14",
    "nx": "^21.5.2",
    "typescript": "^5"
  }
}
